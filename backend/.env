# ── Server ──────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=false

# ── Logging ────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
APP_LOG_LEVEL=INFO

# ── CORS (comma-separated; use * only in dev) ──────────────────────
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── PTY ────────────────────────────────────────────────────────────
# Override default shell. Empty = auto-detect ($SHELL on Unix, cmd.exe on Windows)
APP_DEFAULT_SHELL=powershell.exe
# Replay ring-buffer size in bytes (default 64 KiB)
APP_PTY_BUFFER_LIMIT=65536
